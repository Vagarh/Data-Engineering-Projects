# ML Feature Store Configuration
# ==============================

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
API_DEBUG=false

# Redis (Online Store)
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# PostgreSQL (Offline Store / Registry)
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=feature_store
POSTGRES_USER=feast
POSTGRES_PASSWORD=feast_password

# Feast Configuration
FEAST_REPO_PATH=/app/feature_repo
FEAST_ONLINE_STORE_TYPE=redis
FEAST_OFFLINE_STORE_TYPE=file

# Airflow
AIRFLOW_HOME=/opt/airflow
AIRFLOW__CORE__EXECUTOR=LocalExecutor
AIRFLOW__DATABASE__SQL_ALCHEMY_CONN=postgresql+psycopg2://airflow:airflow@postgres:5432/airflow

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json

# Prometheus Metrics
METRICS_ENABLED=true
METRICS_PORT=9090
